{
  "name": "markingman/cache",
  "description": "Simple PHP file cache",
  "license": "MIT",
  "type": "library",
  "require": {
    "php": ">=8.3"
  },
  "autoload": {
    "psr-4": {
      "MarkIngman\\Cache\\": [
        "src/"
      ]
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MarkIngman\\Cache\\": [
        "tests/"
      ]
    }
  },
  "require-dev": {
    "phpunit/phpunit": "~12.1.2",
    "phpstan/phpstan": "~2.1.22"
  },
  "config": {
    "vendor-dir": "vendor"
  }
}
